{
    "task": [
        {
            "name": "AutoEcoFarm",
            "label": "$task.AutoEcoFarm.label",
            "entry": "AutoEcoFarmMain",
            "description": "$task.AutoEcoFarm.description",
            "controller": [
                "Win32-Front"
            ],
            "option": [
                "FarmlandFindingScheme",
                "AutoEcoFarmClearBagBeforeTasks",
                "AutoEcoFarmClearBagAfterTasks"
            ],
            "group": ["foreground"]
        }
    ],
    "option": {
        "FarmlandFindingScheme": {
            "type": "select",
            "label": "$task.AutoEcoFarm.option.FarmlandFindingScheme.label",
            "default_case": "BRtoTL",
            "cases": [
                {
                    "name": "BRtoTL",
                    "label": "$task.AutoEcoFarm.option.FarmlandFindingScheme.cases[1].label",
                    "pipeline_override": {
                        "_AutoEcoFarmFindFarmlandCustom": {
                            "recognition": {
                                "type": "Custom",
                                "param": {
                                    "custom_recognition": "autoEcoFarmFindNearestRecognitionResult",
                                    "custom_recognition_param": {
                                        "recognitionNodeName": "_AutoEcoFarmFindFarmland",
                                        "xRatio": 0.5,
                                        "yRatio": 0.5
                                    }
                                }
                            }
                        }
                    }
                },
                {
                    "name": "Center",
                    "label": "Goto Center",
                    "pipeline_override": {
                        "_AutoEcoFarmFindFarmlandCustom": {
                            "recognition": {
                                "type": "Custom",
                                "param": {
                                    "custom_recognition": "autoEcoFarmFindNearestRecognitionResult",
                                    "custom_recognition_param": {
                                        "recognitionNodeName": "_AutoEcoFarmFindFarmland",
                                        "xRatio": 0.5,
                                        "yRatio": 0.5
                                    }
                                }
                            }
                        },
                        "_AutoEcoFarmGotoTarget": {
                            "enabled": true
                        },
                        "_AutoEcoFarmIsWorking": {
                            "pre_delay": 60000,
                            "focus": {
                                "Node.Recognition.Succeeded": "等待60秒，让队友多干点活，不是脚本卡咯，别担心"
                            }
                        }
                    }
                }
            ]
        },
        "AutoEcoFarmClearBagBeforeTasks": {
            "type": "switch",
            "label": "$task.AutoEcoFarm.option.AutoEcoFarmClearBagBeforeTasks.label",
            "description": "",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "_AutoEcoFarmPrepareClearBagStart": {
                            "enable": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "_AutoEcoFarmPrepareClearBagStart": {
                            "enable": false
                        }
                    }
                }
            ]
        },
        "AutoEcoFarmClearBagAfterTasks": {
            "type": "switch",
            "label": "$task.AutoEcoFarm.option.AutoEcoFarmClearBagAfterTasks.label",
            "description": "",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "_AutoEcoFarmEndClearBagStart": {
                            "enable": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "_AutoEcoFarmEndClearBagStart": {
                            "enable": false
                        }
                    }
                }
            ]
        }
    }
}
